{
    "compilerOptions": {
        "checkJs": true,
        "noEmit": true,
        "strict": true, "strictPropertyInitialization": false, "strictNullChecks": false,
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": [
            "ESNext",
            "DOM"
        ],
        "paths": {
            "/js/*": [
                "./src/*"
            ]
        }
    },
    "include": [
        "src/**/*.js",
        "htdocs/**/*.js", "types.d.ts"
    ],
    "exclude": [
        "src/lib/**"
    ]
}

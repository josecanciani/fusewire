{
    "compilerOptions": {
        "checkJs": true,
        "noEmit": true,
        "strict": false,
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ESNext", "DOM"],
        "paths": {
            "/js/*": ["./src/*"]
        }
    },
    "include": ["src/**/*.js", "examples/**/*.js"],
    "exclude": ["src/lib/**"]
}

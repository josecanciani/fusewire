{
    "name": "@fusewire/client",
    "version": "1.0.0",
    "description": "FuseWire client-side component framework",
    "type": "module",
    "main": "./src/reactor.js",
    "exports": {
        "./component.js": "./src/component.js",
        "./component-id.js": "./src/component-id.js",
        "./reactor.js": "./src/reactor.js",
        "./renderer.js": "./src/renderer.js",
        "./instance.js": "./src/instance.js",
        "./template.js": "./src/template.js",
        "./template-compiler.js": "./src/template-compiler.js",
        "./template-store.js": "./src/template-store.js",
        "./logger.js": "./src/logger.js",
        "./config.js": "./src/config.js",
        "./errors": "./src/errors/error-hierarchy.js",
        "./utils/dom-helpers.js": "./src/utils/dom-helpers.js",
        "./checks": "./checks/index.js"
    },
    "scripts": {
        "test": "npm run lint && npm run format:check && npm run test:node",
        "test:node": "node --test test/*.test.js test/**/*.test.js",
        "test:browser": "playwright test",
        "test:performance": "node --test test/*.performance-test.js test/**/*.performance-test.js",
        "test:all": "npm run test && npm run test:browser && npm run test:performance",
        "demo": "node demo-server.js",
        "lint": "oxlint src/ htdocs/ && npm run jsdoc-check && npm run typecheck && npm run html-check",
        "format": "oxfmt --write 'src/**/*.{js,css}' 'htdocs/**/*.{js,css}' && npm run format:html",
        "format:check": "oxfmt --check 'src/**/*.{js,css}' 'htdocs/**/*.{js,css}'",
        "format:html": "html-beautify -r 'htdocs/**/*.html'",
        "html-check": "html-validate 'htdocs/**/*.html'",
        "jsdoc-check": "eslint src/ htdocs/",
        "typecheck": "tsc -p jsconfig.json --noEmit"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "eslint": "^10.1.0",
        "eslint-plugin-jsdoc": "^62.8.1",
        "express": "^5.2.1",
        "html-validate": "^10.11.2",
        "http-server": "^14.1.1",
        "js-beautify": "^1.15.4",
        "jsdom": "^29.0.1",
        "oxfmt": "^0.41.0",
        "oxlint": "^1.56.0",
        "typescript": "^6.0.2"
    },
    "dependencies": {
        "idiomorph": "^0.7.4"
    },
    "repository": {
        "type": "git",
        "url": "git@github.com:josecanciani/fusewire.git"
    },
    "keywords": [
        "fusewire",
        "components",
        "reactive",
        "client-side"
    ],
    "author": "Jose Canciani",
    "license": "MIT"
}

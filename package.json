{
    "name": "@fusewire/client",
    "version": "1.0.2",
    "description": "FuseWire client-side component framework",
    "type": "module",
    "main": "./src/reactor.js",
    "exports": {
        "./component.js": {
            "types": "./dist/types/src/component.d.ts",
            "default": "./src/component.js"
        },
        "./component-id.js": {
            "types": "./dist/types/src/component-id.d.ts",
            "default": "./src/component-id.js"
        },
        "./reactor.js": {
            "types": "./dist/types/src/reactor.d.ts",
            "default": "./src/reactor.js"
        },
        "./renderer.js": {
            "types": "./dist/types/src/renderer.d.ts",
            "default": "./src/renderer.js"
        },
        "./instance.js": {
            "types": "./dist/types/src/instance.d.ts",
            "default": "./src/instance.js"
        },
        "./template.js": {
            "types": "./dist/types/src/template.d.ts",
            "default": "./src/template.js"
        },
        "./template-compiler.js": {
            "types": "./dist/types/src/template-compiler.d.ts",
            "default": "./src/template-compiler.js"
        },
        "./template-store.js": {
            "types": "./dist/types/src/template-store.d.ts",
            "default": "./src/template-store.js"
        },
        "./logger.js": {
            "types": "./dist/types/src/logger.d.ts",
            "default": "./src/logger.js"
        },
        "./config.js": {
            "types": "./dist/types/src/config.d.ts",
            "default": "./src/config.js"
        },
        "./errors": {
            "types": "./dist/types/src/errors/error-hierarchy.d.ts",
            "default": "./src/errors/error-hierarchy.js"
        },
        "./utils/dom-helpers.js": {
            "types": "./dist/types/src/utils/dom-helpers.d.ts",
            "default": "./src/utils/dom-helpers.js"
        },
        "./checks": "./checks/index.js"
    },
    "scripts": {
        "test": "npm run lint && npm run format:check && npm run test:node",
        "test:node": "node --test test/*.test.js test/**/*.test.js",
        "test:browser": "playwright test",
        "test:performance": "node --test test/*.performance-test.js test/**/*.performance-test.js",
        "test:all": "npm run test && npm run test:browser && npm run test:performance",
        "demo": "node demo-server.js",
        "lint": "oxlint src/ htdocs/ && npm run jsdoc-check && npm run typecheck && npm run html-check",
        "format": "oxfmt --write 'src/**/*.{js,css}' 'htdocs/**/*.{js,css}' && npm run format:html",
        "format:check": "oxfmt --check 'src/**/*.{js,css}' 'htdocs/**/*.{js,css}'",
        "format:html": "html-beautify -r 'htdocs/**/*.html'",
        "html-check": "html-validate 'htdocs/**/*.html'",
        "jsdoc-check": "eslint src/ htdocs/",
        "typecheck": "npm run build:types",
        "build:types": "tsc -p tsconfig.build.json",
        "build:parser": "node scripts/build-parser.js",
        "changelog": "changelog --url https://github.com/josecanciani/fusewire --head main --no-v-prefix"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "eslint": "^10.1.0",
        "eslint-plugin-jsdoc": "^62.8.1",
        "express": "^5.2.1",
        "html-validate": "^10.11.2",
        "http-server": "^14.1.1",
        "jison": "^0.4.18",
        "js-beautify": "^1.15.4",
        "jsdom": "^29.0.1",
        "keep-a-changelog": "^3.0.2",
        "oxfmt": "^0.41.0",
        "oxlint": "^1.56.0",
        "typescript": "^6.0.2"
    },
    "dependencies": {
        "idiomorph": "^0.7.4"
    },
    "repository": {
        "type": "git",
        "url": "git@github.com:josecanciani/fusewire.git"
    },
    "keywords": [
        "fusewire",
        "components",
        "reactive",
        "client-side"
    ],
    "author": "Jose Canciani",
    "license": "MIT",
    "types": "./dist/types/src/reactor.d.ts"
}
